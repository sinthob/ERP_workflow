<UserControl
    x:Class="Sortable.Avalonia.Demo.Views.Demos.HorizontalStackDemoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sortable.Avalonia.Demo.Models"
    xmlns:sortable="clr-namespace:Sortable.Avalonia;assembly=Sortable.Avalonia"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:Sortable.Avalonia.Demo.ViewModels.Demos"
    xmlns:logmodels="using:Sortable.Avalonia.Demo.Models"
    x:DataType="vm:HorizontalStackDemoViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:HorizontalStackDemoViewModel />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Sprint Pipeline" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Drag stages left or right to reprioritize your sprint flow. Each stage shows an emoji icon and item count."
                TextWrapping="Wrap" />
            <ui:InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="Drag stage cards horizontally to reorder pipeline steps."
                Severity="Informational"
                Title="Tip" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Theme="{StaticResource AccentButtonTheme}" Command="{Binding SortHorizontalItemsProgrammaticallyCommand}" Content="Move Last Stage to Front" />
                <Button Command="{Binding RandomizeHorizontalItemsCommand}" Content="Shuffle Stages" />
            </StackPanel>
            <Border
                Padding="16"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                CornerRadius="8">
                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                    <ItemsControl
                        sortable:Sortable.ReleaseCommand="{Binding ItemReleaseCommand}"
                        sortable:Sortable.Sortable="True"
                        sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                        ItemsSource="{Binding HorizontalItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="10" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:SortableItem">
                                <Border
                                    Width="160"
                                    sortable:Sortable.IsSortable="True"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Cursor="Hand">
                                    <Grid RowDefinitions="4,*">
                                        <Border
                                            Grid.Row="0"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            CornerRadius="7,7,0,0" />
                                        <StackPanel
                                            Grid.Row="1"
                                            Margin="14,12,14,14"
                                            Spacing="6">
                                            <TextBlock
                                                FontSize="26"
                                                HorizontalAlignment="Center"
                                                Text="{Binding Tag}" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Center"
                                                Text="{Binding Name}"
                                                TextAlignment="Center"
                                                TextWrapping="Wrap" />
                                            <Border
                                                HorizontalAlignment="Center"
                                                Padding="8,3"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="10">
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Note}" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
            <!-- Event Log Panel -->
            <Border
                Padding="12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon FontSize="14" Symbol="Clock" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Event Log" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ClearEventLogCommand}" Content="Clear" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="logmodels:EventLogEntry">
                                    <Grid ColumnDefinitions="55,20,*" ColumnSpacing="6" Margin="0,2">
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            Text="{Binding Time}" />
                                        <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center" Text="{Binding Emoji}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
