<UserControl
    x:Class="Sortable.Avalonia.Demo.Views.Demos.SwapModeDemoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sortable.Avalonia.Demo.Models"
    xmlns:sortable="clr-namespace:Sortable.Avalonia;assembly=Sortable.Avalonia"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:Sortable.Avalonia.Demo.ViewModels.Demos"
    xmlns:logmodels="using:Sortable.Avalonia.Demo.Models"
    x:DataType="vm:SwapModeDemoViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:SwapModeDemoViewModel />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="On-Call Roster" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Drag one engineer over another to swap their on-call slots. No one else is reordered — a direct 1-for-1 exchange."
                TextWrapping="Wrap" />
            <ui:InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="Swap Mode: dragging A onto B exchanges positions. No other items move."
                Severity="Informational"
                Title="Swap Mode" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Theme="{StaticResource AccentButtonTheme}" Command="{Binding SwapModeItemsProgrammaticallyCommand}" Content="Swap First &amp; Last Slot" />
                <Button Command="{Binding RandomizeSwapModeCommand}" Content="Random Swap" />
            </StackPanel>
            <Border
                MaxWidth="560"
                Padding="12"
                HorizontalAlignment="Left"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                CornerRadius="8">
                <ItemsControl
                    sortable:Sortable.Mode="Swap"
                    sortable:Sortable.Sortable="True"
                    sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                    ItemsSource="{Binding SwapModeItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:SortableItem">
                            <Border
                                sortable:Sortable.IsSortable="True"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Cursor="Hand">
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,10" ColumnSpacing="12">
                                    <!-- Avatar circle -->
                                    <Border
                                        Grid.Column="0"
                                        Width="40"
                                        Height="40"
                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                        CornerRadius="20">
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Text="{Binding Tag}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Note}" />
                                    </StackPanel>
                                    <CheckBox
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Content="Confirmed"
                                        IsChecked="{Binding Reviewed, Mode=TwoWay}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
            <!-- Event Log Panel -->
            <Border
                Padding="12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon FontSize="14" Symbol="Clock" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Event Log" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ClearEventLogCommand}" Content="Clear" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="logmodels:EventLogEntry">
                                    <Grid ColumnDefinitions="55,20,*" ColumnSpacing="6" Margin="0,2">
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            Text="{Binding Time}" />
                                        <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center" Text="{Binding Emoji}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
