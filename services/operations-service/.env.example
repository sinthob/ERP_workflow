# Operations Service (Team 3)
# ERPNext is the System of Record — do NOT connect to ERPNext DB directly.

# Base URL of ERPNext/Frappe (from frappe_docker/pwd.yml typically http://localhost:8080)
ERP_BASE_URL=http://localhost:8080

# Use REST API auth token (recommended for service-to-service)
# In ERPNext: User -> API Access -> API Key/Secret
ERP_API_KEY=
ERP_API_SECRET=

# Optional shared secret for incoming webhooks into this service
WEBHOOK_TOKEN=change-me

# This service
SERVICE_PORT=8003
