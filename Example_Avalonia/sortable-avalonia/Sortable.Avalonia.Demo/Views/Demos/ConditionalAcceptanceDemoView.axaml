<UserControl
    x:Class="Sortable.Avalonia.Demo.Views.Demos.ConditionalAcceptanceDemoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sortable.Avalonia.Demo.Models"
    xmlns:sortable="clr-namespace:Sortable.Avalonia;assembly=Sortable.Avalonia"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:Sortable.Avalonia.Demo.ViewModels.Demos"
    xmlns:logmodels="using:Sortable.Avalonia.Demo.Models"
    x:DataType="vm:ConditionalAcceptanceDemoViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:ConditionalAcceptanceDemoViewModel />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Priority Incident Gate" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Only URGENT-tagged incidents can be dragged into the Hotfix Queue. Normal items are rejected with IsAccepted=False."
                TextWrapping="Wrap" />
            <ui:InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="The drop command sets IsAccepted=False to reject items that don't meet the URGENT condition."
                Severity="Informational"
                Title="How It Works" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <StackPanel Grid.Column="0" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ui:SymbolIcon Symbol="Mail" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Text="All Incidents" />
                    </StackPanel>
                    <Border
                        Padding="10"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8">
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding ConditionalItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="conditional-demo"
                            ItemsSource="{Binding ConditionalSourceItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="4,*">
                                            <Border
                                                Grid.Column="0"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="5,0,0,5" />
                                            <StackPanel Grid.Column="1" Margin="10,9" Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Name}"
                                                        TextWrapping="Wrap" />
                                                    <Border
                                                        Grid.Column="1"
                                                        Padding="6,2"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="3">
                                                        <TextBlock FontSize="9" FontWeight="Bold" Foreground="White" Text="{Binding Tag}" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Note}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ui:SymbolIcon Symbol="Alert" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Text="Hotfix Queue (URGENT only)" />
                    </StackPanel>
                    <Border
                        Padding="10"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8">
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding ConditionalItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="conditional-demo"
                            ItemsSource="{Binding ConditionalTargetItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="4,*">
                                            <Border
                                                Grid.Column="0"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="5,0,0,5" />
                                            <StackPanel Grid.Column="1" Margin="10,9" Spacing="4">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Text="{Binding Name}"
                                                        TextWrapping="Wrap" />
                                                    <Border
                                                        Grid.Column="1"
                                                        Padding="6,2"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="3">
                                                        <TextBlock FontSize="9" FontWeight="Bold" Foreground="White" Text="{Binding Tag}" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock
                                                    FontSize="11"
                                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                    Text="{Binding Note}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>
            <!-- Event Log Panel -->
            <Border
                Padding="12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon FontSize="14" Symbol="Clock" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Event Log" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ClearEventLogCommand}" Content="Clear" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="logmodels:EventLogEntry">
                                    <Grid ColumnDefinitions="55,20,*" ColumnSpacing="6" Margin="0,2">
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            Text="{Binding Time}" />
                                        <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center" Text="{Binding Emoji}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
