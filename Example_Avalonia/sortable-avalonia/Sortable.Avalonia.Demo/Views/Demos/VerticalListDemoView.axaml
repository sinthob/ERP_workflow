<UserControl
    x:Class="Sortable.Avalonia.Demo.Views.Demos.VerticalListDemoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sortable.Avalonia.Demo.Models"
    xmlns:sortable="clr-namespace:Sortable.Avalonia;assembly=Sortable.Avalonia"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:Sortable.Avalonia.Demo.ViewModels.Demos"
    xmlns:logmodels="using:Sortable.Avalonia.Demo.Models"
    x:DataType="vm:VerticalListDemoViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:VerticalListDemoViewModel />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Project Priority Queue" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Drag cards to reprioritize work. Each card shows a priority badge, owner team, and current status."
                TextWrapping="Wrap" />
            <ui:InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="Drag any card to reorder. Embedded TextBox, CheckBox and Button controls remain fully interactive."
                Severity="Informational"
                Title="Tip" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Theme="{StaticResource AccentButtonTheme}" Command="{Binding SortSimpleListProgrammaticallyCommand}" Content="Escalate Last Item" />
                <Button Command="{Binding RandomizeSimpleListCommand}" Content="Shuffle Queue" />
                <Button Command="{Binding LoadItemsCommand}" Content="Reset Queue" />
            </StackPanel>
            <ItemsControl
                MaxWidth="640"
                HorizontalAlignment="Left"
                sortable:Sortable.Sortable="True"
                sortable:Sortable.ReleaseCommand="{Binding ItemReleasedCommand}"
                sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                ItemsSource="{Binding SimpleList}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="6" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:SortableItem">
                        <Border
                            sortable:Sortable.IsSortable="True"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Cursor="Hand">
                            <Grid ColumnDefinitions="4,*">
                                <Border
                                    Grid.Column="0"
                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                    CornerRadius="5,0,0,5" />
                                <StackPanel Grid.Column="1" Margin="14,12,14,12" Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontWeight="SemiBold"
                                            Text="{Binding Name}"
                                            TextWrapping="Wrap" />
                                        <Border
                                            Grid.Column="1"
                                            Padding="7,3"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource AccentFillColorDefaultBrush}"
                                            CornerRadius="4">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Foreground="White"
                                                Text="{Binding Tag}" />
                                        </Border>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <TextBox Text="{Binding Note, Mode=TwoWay}" Watermark="Add execution note…" />
                                        <CheckBox Grid.Column="1" Content="Done" IsChecked="{Binding Reviewed, Mode=TwoWay}" />
                                        <Button Grid.Column="2" Content="Open" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <!-- Event Log Panel -->
            <Border
                Padding="12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon FontSize="14" Symbol="Clock" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Event Log" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ClearEventLogCommand}" Content="Clear" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="logmodels:EventLogEntry">
                                    <Grid ColumnDefinitions="55,20,*" ColumnSpacing="6" Margin="0,2">
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            Text="{Binding Time}" />
                                        <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center" Text="{Binding Emoji}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
