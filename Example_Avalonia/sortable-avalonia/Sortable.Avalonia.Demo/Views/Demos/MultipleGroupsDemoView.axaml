<UserControl
    x:Class="Sortable.Avalonia.Demo.Views.Demos.MultipleGroupsDemoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sortable.Avalonia.Demo.Models"
    xmlns:sortable="clr-namespace:Sortable.Avalonia;assembly=Sortable.Avalonia"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:Sortable.Avalonia.Demo.ViewModels.Demos"
    xmlns:logmodels="using:Sortable.Avalonia.Demo.Models"
    x:DataType="vm:MultipleGroupsDemoViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:MultipleGroupsDemoViewModel />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Team-Scoped Work Queues" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Design tasks can move only between Design queues. Security tasks only between Security queues. Cross-team transfer is prevented."
                TextWrapping="Wrap" />
            <ui:InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="Collections sharing the same group key exchange items. Different group keys create isolated drag scopes."
                Severity="Informational"
                Title="Tip" />
            <UniformGrid ColumnSpacing="16" Columns="2" RowSpacing="16">
                <!-- Design Queue A -->
                <Border
                    Padding="10"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border
                                Width="6"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="3" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Design · Sprint A" />
                        </StackPanel>
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding ItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="groupA"
                            sortable:Sortable.Sortable="True"
                            sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                            ItemsSource="{Binding GroupA1}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        sortable:Sortable.IsSortable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="4,*">
                                            <Border
                                                Grid.Column="0"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="5,0,0,5" />
                                            <StackPanel Grid.Column="1" Margin="10,8" Spacing="2">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1" FontSize="14" Text="{Binding Tag}" />
                                                </Grid>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding Note}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <!-- Design Queue B -->
                <Border
                    Padding="10"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border
                                Width="6"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                CornerRadius="3" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Design · Sprint B" />
                        </StackPanel>
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding ItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="groupA"
                            sortable:Sortable.Sortable="True"
                            sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                            ItemsSource="{Binding GroupA2}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        sortable:Sortable.IsSortable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="4,*">
                                            <Border
                                                Grid.Column="0"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="5,0,0,5" />
                                            <StackPanel Grid.Column="1" Margin="10,8" Spacing="2">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1" FontSize="14" Text="{Binding Tag}" />
                                                </Grid>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding Note}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <!-- Security Queue A -->
                <Border
                    Padding="10"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border
                                Width="6"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="3" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Security · Queue A" />
                        </StackPanel>
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding ItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="groupB"
                            sortable:Sortable.Sortable="True"
                            sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                            ItemsSource="{Binding GroupB1}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        sortable:Sortable.IsSortable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="4,*">
                                            <Border
                                                Grid.Column="0"
                                                Background="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                                                CornerRadius="5,0,0,5" />
                                            <StackPanel Grid.Column="1" Margin="10,8" Spacing="2">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1" FontSize="14" Text="{Binding Tag}" />
                                                </Grid>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding Note}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <!-- Security Queue B -->
                <Border
                    Padding="10"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border
                                Width="6"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="3" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Security · Queue B" />
                        </StackPanel>
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding ItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="groupB"
                            sortable:Sortable.Sortable="True"
                            sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                            ItemsSource="{Binding GroupB2}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        sortable:Sortable.IsSortable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="4,*">
                                            <Border
                                                Grid.Column="0"
                                                Background="{DynamicResource ControlStrongStrokeColorDefaultBrush}"
                                                CornerRadius="5,0,0,5" />
                                            <StackPanel Grid.Column="1" Margin="10,8" Spacing="2">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Column="1" FontSize="14" Text="{Binding Tag}" />
                                                </Grid>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding Note}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </UniformGrid>
            <!-- Event Log Panel -->
            <Border
                Padding="12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon FontSize="14" Symbol="Clock" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Event Log" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ClearEventLogCommand}" Content="Clear" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="logmodels:EventLogEntry">
                                    <Grid ColumnDefinitions="55,20,*" ColumnSpacing="6" Margin="0,2">
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            Text="{Binding Time}" />
                                        <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center" Text="{Binding Emoji}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
