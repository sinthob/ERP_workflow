<UserControl
    x:Class="Sortable.Avalonia.Demo.Views.Demos.KanbanBoardDemoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:logmodels="using:Sortable.Avalonia.Demo.Models"
    xmlns:models="using:Sortable.Avalonia.Demo.Models"
    xmlns:sortable="clr-namespace:Sortable.Avalonia;assembly=Sortable.Avalonia"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:Sortable.Avalonia.Demo.ViewModels.Demos"
    x:DataType="vm:KanbanBoardDemoViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:KanbanBoardDemoViewModel />
    </Design.DataContext>

    <Grid Margin="24" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
        <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Text="Kanban Board" />
        <ui:InfoBar
            Grid.Row="1"
            IsClosable="False"
            IsOpen="True"
            Message="Drag cards between columns to transfer them, or reorder within a column. Priority emoji shows severity at a glance."
            Severity="Informational"
            Title="Tip" />
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Columns}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid ColumnSpacing="12" Columns="4" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:KanbanColumn">
                    <Border
                        Padding="10"
                        Background="{DynamicResource LayerFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <Border
                                Grid.Row="0"
                                Padding="10,7"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="5">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ui:SymbolIcon FontSize="14" Symbol="List" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Text="{Binding Title}" />
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1">
                                <ItemsControl
                                    sortable:Sortable.DropCommand="{Binding $parent[UserControl].((vm:KanbanBoardDemoViewModel)DataContext).ItemDroppedCommand}"
                                    sortable:Sortable.Droppable="True"
                                    sortable:Sortable.Group="kanban"
                                    sortable:Sortable.Sortable="True"
                                    sortable:Sortable.UpdateCommand="{Binding $parent[UserControl].((vm:KanbanBoardDemoViewModel)DataContext).ItemUpdatedCommand}"
                                    ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel VerticalAlignment="Top" Spacing="6" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="models:SortableItem">
                                            <Border
                                                sortable:Sortable.IsDroppable="True"
                                                sortable:Sortable.IsSortable="True"
                                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Cursor="Hand">
                                                <Grid ColumnDefinitions="4,*">
                                                    <Border
                                                        Grid.Column="0"
                                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                        CornerRadius="5,0,0,5" />
                                                    <StackPanel Grid.Column="1" Margin="10,9" Spacing="5">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                            <TextBlock
                                                                VerticalAlignment="Center"
                                                                FontSize="12"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding Name}"
                                                                TextWrapping="Wrap" />
                                                            <TextBlock
                                                                Grid.Column="1"
                                                                VerticalAlignment="Center"
                                                                FontSize="14"
                                                                Text="{Binding Tag}" />
                                                        </Grid>
                                                        <TextBlock
                                                            FontSize="11"
                                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                            Text="{Binding Note}"
                                                            TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <!-- Event Log Panel -->
        <Border
            Grid.Row="3"
            Padding="12"
            Background="{DynamicResource LayerFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                        <ui:SymbolIcon FontSize="14" Symbol="Clock" VerticalAlignment="Center" />
                        <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Event Log" />
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding ClearEventLogCommand}" Content="Clear" />
                </Grid>
                <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding EventLog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="logmodels:EventLogEntry">
                                <Grid ColumnDefinitions="55,20,*" ColumnSpacing="6" Margin="0,2">
                                    <TextBlock
                                        Grid.Column="0"
                                        FontSize="11"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        VerticalAlignment="Center"
                                        Text="{Binding Time}" />
                                    <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center" Text="{Binding Emoji}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Text="{Binding Message}"
                                        TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
