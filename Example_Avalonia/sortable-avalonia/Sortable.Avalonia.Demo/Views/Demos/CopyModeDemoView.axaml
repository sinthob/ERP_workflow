<UserControl
    x:Class="Sortable.Avalonia.Demo.Views.Demos.CopyModeDemoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sortable.Avalonia.Demo.Models"
    xmlns:sortable="clr-namespace:Sortable.Avalonia;assembly=Sortable.Avalonia"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:Sortable.Avalonia.Demo.ViewModels.Demos"
    xmlns:logmodels="using:Sortable.Avalonia.Demo.Models"
    x:DataType="vm:CopyModeDemoViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:CopyModeDemoViewModel />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Message Template Library" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Drag templates from the catalog into your campaign draft. The original stays in the library — a copy is added to the draft."
                TextWrapping="Wrap" />
            <ui:InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="Copy Mode: the source item is never removed. Only a copy lands in the target collection."
                Severity="Success"
                Title="Copy Mode" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <StackPanel Grid.Column="0" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ui:SymbolIcon Symbol="Library" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Text="Template Catalog" />
                    </StackPanel>
                    <Border
                        Padding="10"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8">
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding CopyModeItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="copy-demo"
                            ItemsSource="{Binding CopySourceItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="10,9" ColumnSpacing="10">
                                            <Border
                                                Grid.Column="0"
                                                Width="32"
                                                Height="32"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="6">
                                                <ui:SymbolIcon
                                                    FontSize="16"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Symbol="Mail" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" />
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding Note}" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="2"
                                                Padding="5,2"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="3">
                                                <TextBlock FontSize="9" FontWeight="Bold" Foreground="White" Text="{Binding Tag}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ui:SymbolIcon Symbol="Edit" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Text="Campaign Draft" />
                    </StackPanel>
                    <Border
                        Padding="10"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                        CornerRadius="8">
                        <ItemsControl
                            sortable:Sortable.DropCommand="{Binding CopyModeItemDroppedCommand}"
                            sortable:Sortable.Droppable="True"
                            sortable:Sortable.Group="copy-demo"
                            ItemsSource="{Binding CopyTargetItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortableItem">
                                    <Border
                                        sortable:Sortable.IsDroppable="True"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Cursor="Hand">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="10,9" ColumnSpacing="10">
                                            <Border
                                                Grid.Column="0"
                                                Width="32"
                                                Height="32"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="6">
                                                <ui:SymbolIcon
                                                    FontSize="16"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Symbol="Document" />
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding Name}" />
                                                <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{Binding Note}" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="2"
                                                Padding="5,2"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                CornerRadius="3">
                                                <TextBlock FontSize="9" FontWeight="Bold" Text="{Binding Tag}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>
            <!-- Event Log Panel -->
            <Border
                Padding="12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon FontSize="14" Symbol="Clock" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Event Log" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ClearEventLogCommand}" Content="Clear" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="logmodels:EventLogEntry">
                                    <Grid ColumnDefinitions="55,20,*" ColumnSpacing="6" Margin="0,2">
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            Text="{Binding Time}" />
                                        <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center" Text="{Binding Emoji}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
