<UserControl
    x:Class="Sortable.Avalonia.Demo.Views.Demos.DragHandleDemoView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sortable.Avalonia.Demo.Models"
    xmlns:sortable="clr-namespace:Sortable.Avalonia;assembly=Sortable.Avalonia"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:Sortable.Avalonia.Demo.ViewModels.Demos"
    xmlns:logmodels="using:Sortable.Avalonia.Demo.Models"
    x:DataType="vm:DragHandleDemoViewModel"
    mc:Ignorable="d">
    <Design.DataContext>
        <vm:DragHandleDemoViewModel />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Text="Reorder Settings Sections" />
            <TextBlock
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Drag the grip handle on the left to reorder settings sections. All other controls stay interactive."
                TextWrapping="Wrap" />
            <ui:InfoBar
                IsClosable="False"
                IsOpen="True"
                Message="Only the grip handle (⠿) initiates drag. Text, buttons and toggles inside items remain interactive."
                Severity="Informational"
                Title="Tip" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Theme="{StaticResource AccentButtonTheme}" Command="{Binding MoveLastHandleItemToTopCommand}" Content="Move Last Section to Top" />
            </StackPanel>
            <Border
                MaxWidth="640"
                Padding="14"
                HorizontalAlignment="Left"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                CornerRadius="8">
                <ItemsControl
                    sortable:Sortable.Sortable="True"
                    sortable:Sortable.UpdateCommand="{Binding ItemUpdatedCommand}"
                    ItemsSource="{Binding DragHandleItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:SortableItem">
                            <Border
                                sortable:Sortable.IsSortable="True"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="0">
                                    <!-- Drag handle -->
                                    <Border
                                        Grid.Column="0"
                                        Width="36"
                                        sortable:Sortable.IsDragHandle="True"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="5,0,0,5"
                                        Cursor="Hand">
                                        <ui:SymbolIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Symbol="MoreVertical" />
                                    </Border>
                                    <!-- Icon -->
                                    <Border
                                        Grid.Column="1"
                                        Width="40"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                        <TextBlock
                                            FontSize="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Text="{Binding Tag}" />
                                    </Border>
                                    <!-- Text content -->
                                    <StackPanel Grid.Column="2" Margin="14,12" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Note}" />
                                    </StackPanel>
                                    <!-- Action -->
                                    <StackPanel
                                        Grid.Column="3"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                        <CheckBox Content="Visible" IsChecked="{Binding Reviewed, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
            <!-- Event Log Panel -->
            <Border
                Padding="12"
                Background="{DynamicResource LayerFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                            <ui:SymbolIcon FontSize="14" Symbol="Clock" VerticalAlignment="Center" />
                            <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Text="Event Log" />
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding ClearEventLogCommand}" Content="Clear" />
                    </Grid>
                    <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Opacity="0.5" />
                    <ScrollViewer MaxHeight="130" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLog}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="logmodels:EventLogEntry">
                                    <Grid ColumnDefinitions="55,20,*" ColumnSpacing="6" Margin="0,2">
                                        <TextBlock
                                            Grid.Column="0"
                                            FontSize="11"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center"
                                            Text="{Binding Time}" />
                                        <TextBlock Grid.Column="1" FontSize="13" VerticalAlignment="Center" Text="{Binding Emoji}" />
                                        <TextBlock
                                            Grid.Column="2"
                                            FontSize="12"
                                            VerticalAlignment="Center"
                                            Text="{Binding Message}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
